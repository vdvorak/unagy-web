# Lokální dev image — Vite dev server (HMR). Node nejnovější LTS.
# Build context = scaffold root (clients/web po kopii). node_modules zůstává v image,
# zdroják se mountuje přes compose (viz docker-compose.dev.yml).
FROM node:22-slim
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm install
COPY . .
EXPOSE 5173
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
