{
  "name": "app-web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "dependencies": {
    "@kobalte/core": "^0.13.0",
    "@mbarzda/solid-i18next": "^1.4.0",
    "@solidjs/router": "^0.14.0",
    "i18next": "^23.0.0",
    "lucide-solid": "^0.468.0",
    "openapi-fetch": "^0.13.0",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.0",
    "@testing-library/jest-dom": "^6.4.0",
    "eslint": "^10.4.1",
    "jsdom": "^25.0.0",
    "prettier": "^3.4.0",
    "msw": "^2.0.0",
    "openapi-typescript": "^7.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.61.0",
    "vite": "^5.4.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^2.1.0"
  }
}
