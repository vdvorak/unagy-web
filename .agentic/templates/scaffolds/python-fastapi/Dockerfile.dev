# Lokální dev image — uvicorn s hot-reloadem (vč. dev závislostí pro testy v kontejneru).
# Postgres je samostatný compose service (NE embedded). Build context = scaffold root.
FROM python:3.12-slim
WORKDIR /app/server
COPY server/requirements.txt server/requirements-dev.txt ./
RUN pip install --no-cache-dir -r requirements.txt -r requirements-dev.txt
EXPOSE 8000
CMD ["uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
